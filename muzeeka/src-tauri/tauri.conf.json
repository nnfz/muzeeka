{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "muzeeka",
  "version": "0.1.0",
  "identifier": "com.nnfz.muzeeka",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Muzeeka",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost https://lyrics-api.boidu.dev https://unison.boidu.dev https://lrclib.net; style-src 'self' 'unsafe-inline'; font-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost data: blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*", "$APPLOCALDATA/**/*"]
      }
    }
  },
  "plugins": {
    "taskbar": {
      "autoAttach": false,
      "windowLabel": "main",
      "tooltips": {
        "previous": "Предыдущий",
        "play": "Воспроизвести",
        "pause": "Пауза",
        "next": "Следующий"
      },
      "icons": {
        "previous": "icons/taskbar/PREV_THUMB.ico",
        "previousDisabled": "icons/taskbar/PREV_THUMB_DISABLED.ico",
        "play": "icons/taskbar/PLAY_THUMB.ico",
        "pause": "icons/taskbar/PAUSE_THUMB.ico",
        "next": "icons/taskbar/NEXT_THUMB.ico",
        "nextDisabled": "icons/taskbar/NEXT_THUMB_DISABLED.ico"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "bass/": "bass",
      "bin/": "bin",
      "icons/taskbar/": "icons/taskbar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
